<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      spacing="20"
      alignment="CENTER"
      stylesheets="@../css/styles.css"
      fx:controller="views.shared.InventoryFXMLController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Titre principal -->
    <Label text="INVENTAIRE BUGÉMON"
           maxWidth="Infinity"
           alignment="CENTER"
           styleClass="section-header"/>

    <!-- Sous-titre -->
    <Label text="Veuillez choisir un objet"
           maxWidth="Infinity"
           alignment="CENTER"
           styleClass="section-header-dark"/>

    <!-- Zone scrollable avec FlowPane pour les objets -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-transparent">
            <FlowPane fx:id="itemsContainer"
                      hgap="20"
                      vgap="20"
                      alignment="CENTER">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
            </FlowPane>
    </ScrollPane>

    <!-- HBox pour afficher les objets choisis -->
    <HBox fx:id="selectedItemsBar"
          spacing="15"
          alignment="CENTER"
          prefHeight="50"
          styleClass="list-panel">
        <!-- Labels des objets choisis seront ajoutés dynamiquement -->
    </HBox>

    <!-- Boutons centrés -->
    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="cancelButton"
                text="Annuler"
                styleClass="btn-cancel"
                prefWidth="200" prefHeight="50"/>
        <Button fx:id="confirmButton"
                text="Confirmer"
                styleClass="btn-confirm"
                prefWidth="200" prefHeight="50"/>
    </HBox>

</VBox>
