<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="views.tower.endscreen.FloorUnlockFXMLController"
      alignment="TOP_CENTER"
      spacing="20"
      styleClass="scene-bg-white"
      stylesheets="@../css/styles.css">

    <padding><Insets top="30" right="50" bottom="30" left="50"/></padding>

    <Label fx:id="floorLabel" text="Étage —" styleClass="floor-indicator"/>

    <Label text="ÉTAGE DÉBLOQUÉ !" styleClass="title-win"/>

    <Label text="Vous avez vaincu le boss !" styleClass="section-subtitle"/>

    <Separator/>

    <Label text="État de votre équipe" styleClass="section-header-dark"/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-container">
        <VBox fx:id="vboxBugemons" spacing="8" styleClass="scroll-inner">
        </VBox>
    </ScrollPane>

    <Separator/>

    <HBox alignment="CENTER" spacing="20">
        <Button fx:id="mainmenuButton" text="Menu Principal" styleClass="btn-menu"/>
        <Button fx:id="continueButton" text="Continuer  ▶" styleClass="btn-win-next"/>
    </HBox>

</VBox>
